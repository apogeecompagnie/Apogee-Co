<script>
const PAGE_T={fr:{hero_eyebrow:"HÔTELLERIE · PRESTIGE",hero_title:"Services Hôteliers",hero_desc:"Des prestations hôtelières pour établissements exigeants. Nous élevons l'expérience de vos clients à un niveau supérieur.",tl_pre:"NOS PRESTATIONS",tl_title:"Des standards d'exception",quote:"",names:["Accueil & Réception","Ménage & Entretien Chambres","Restauration & Room Service","Bien-être & Spa","Blanchisserie Hôtelière"],descs:["Accueil personnalisé de vos clients selon les standards de votre établissement. Check-in, check-out, concierge desk en plusieurs langues.","Nettoyage aux standards hôteliers internationaux avec protocole de contrôle qualité. Deep cleaning, mise en place du linge.","Mise en place et service du petit-déjeuner, room service, organisation de buffets et déjeuners de groupe.","Prestations de bien-être en chambre : massages, soins du visage, yoga. Thérapeutes certifiés se déplaçant dans votre établissement.","Collecte, traitement et restitution du linge selon les protocoles hôteliers. Draps, serviettes, peignoirs, uniformes."],tags:[["Check-in / Check-out","Concierge desk","Multilingue"],["Standards internationaux","Deep cleaning","Contrôle qualité"],["Petit-déjeuner","Room service","Buffets & groupe"],["Massage en chambre","Soins beauté","Yoga & méditation"],["Collecte & livraison","Traitement professionnel","Uniformes"]]},en:{hero_eyebrow:"HOSPITALITY · PRESTIGE",hero_title:"Hospitality Services",hero_desc:"Exceptional hospitality services for demanding establishments. We elevate your guests experience to a higher level.",tl_pre:"OUR SERVICES",tl_title:"Exceptional hotel standards",quote:"",names:["Guest Welcome & Reception","Room Cleaning & Housekeeping","Catering & Room Service","Wellness & Spa","Hotel Laundry"],descs:["Personalised guest welcome to your establishment standards. Check-in, check-out, concierge desk in multiple languages.","Cleaning to international hotel standards with quality control protocols. Deep cleaning and linen setup.","Breakfast setup and service, in-room service, buffet and group lunch organisation.","Wellness services in room: massages, facial treatments, yoga. Certified therapists come to your establishment.","Collection, processing and return of linen to hotel protocols. Sheets, towels, robes, uniforms."],tags:[["Check-in / Check-out","Concierge desk","Multilingual"],["International standards","Deep cleaning","Quality control"],["Breakfast","Room service","Buffets & groups"],["In-room massage","Beauty treatments","Yoga & meditation"],["Collection & delivery","Professional treatment","Uniforms"]]}};
function applyPageT(l){
  const p=PAGE_T[l]||PAGE_T.fr;
  const g=id=>document.getElementById(id);
  if(g("svc-eyebrow"))g("svc-eyebrow").textContent=p.hero_eyebrow;
  if(g("svc-title"))g("svc-title").textContent=p.hero_title;
  if(g("svc-desc"))g("svc-desc").textContent=p.hero_desc;
  if(g("svc-tl-pre"))g("svc-tl-pre").textContent=p.tl_pre;
  if(g("svc-tl-title"))g("svc-tl-title").textContent=p.tl_title;
  if(g("svc-quote")&&p.quote)g("svc-quote").textContent=p.quote;
  p.names.forEach((n,i)=>{
    document.querySelectorAll(".svc-tl-name-"+i).forEach(el=>el.textContent=n);
    document.querySelectorAll(".svc-tl-desc-"+i).forEach(el=>el.textContent=p.descs[i]);
    document.querySelectorAll(".svc-tl-tags-"+i).forEach(el=>{
      el.innerHTML=p.tags[i].map(t=>"<span class=\"svc-tl-tag\">"+t+"</span>").join("");
    });
  });
}
document.addEventListener("DOMContentLoaded",()=>applyPageT(lang));
const _origSetLang=setLang;
window.setLang=function(l){_origSetLang(l);applyPageT(l);};
</script>
