<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Services Hôteliers — Apogée & Co</title>
<meta name="description" content="Apogée & Co — Services Hôteliers Prestige.">
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap');
:root{--navy:#0e1629;--navy2:#1a2744;--gold:#C9A84C;--gold-l:#e8d5a3;--gray:#8a9ab8;--text:#d4c9b0;--cream:#f5f0e8;}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:var(--navy);color:var(--text);overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 4vw;height:72px;background:rgba(14,22,41,0.97);backdrop-filter:blur(8px);transition:height 0.3s;}
nav.scrolled{height:60px;}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-logo img{height:42px;width:42px;transition:height 0.3s;}
nav.scrolled .nav-logo img{height:34px;width:34px;}
.nav-brand{font-family:'Cormorant Garamond',serif;font-size:17px;letter-spacing:0.2em;color:var(--gold);}
.nav-brand span{display:block;font-size:7.5px;font-family:'Montserrat',sans-serif;letter-spacing:0.3em;color:var(--gray);font-weight:300;margin-top:1px;}
.nav-links{display:flex;gap:26px;list-style:none;align-items:center;}
.nav-links a{font-size:10px;letter-spacing:0.2em;color:var(--gray);text-decoration:none;text-transform:uppercase;transition:color 0.3s;position:relative;padding-bottom:2px;}
.nav-links a:hover,.nav-links a.active{color:var(--gold);}
.nav-links a.active::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--gold);}
.nav-right{display:flex;align-items:center;gap:12px;}
.nav-cta{font-size:10px;letter-spacing:0.2em;color:var(--gold);border:1px solid var(--gold);padding:8px 18px;text-decoration:none;transition:all 0.3s;}
.nav-cta:hover{background:var(--gold);color:var(--navy);}
.lang-btn{font-size:9px;letter-spacing:0.25em;color:var(--gray);background:transparent;border:1px solid rgba(138,154,184,0.3);padding:7px 12px;cursor:pointer;font-family:'Montserrat',sans-serif;transition:all 0.3s;}
.lang-btn:hover{color:var(--gold);border-color:rgba(201,168,76,0.4);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.hamburger span{width:22px;height:1.5px;background:var(--gold);transition:all 0.3s;display:block;}
.mobile-menu{display:none;position:fixed;top:72px;left:0;right:0;background:rgba(14,22,41,0.98);padding:24px 6vw;flex-direction:column;gap:16px;z-index:199;}
.mobile-menu.open{display:flex;}
.mobile-menu a{font-size:12px;letter-spacing:0.2em;color:var(--gray);text-decoration:none;padding:8px 0;transition:color 0.3s;}
.mobile-menu a:hover{color:var(--gold);}
/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;background:var(--navy);padding-top:72px;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(201,168,76,0.06) 0%,transparent 70%);}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(201,168,76,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,0.03) 1px,transparent 1px);background-size:60px 60px;}
.hero-content{text-align:center;position:relative;z-index:2;padding:0 5vw;max-width:880px;}
.hero-pre{font-size:10px;letter-spacing:0.5em;color:var(--gold);margin-bottom:28px;display:flex;align-items:center;justify-content:center;gap:16px;}
.hero-pre::before,.hero-pre::after{display:none;}
.hero-logo{width:120px;height:120px;margin:0 auto 32px;}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(40px,7vw,78px);font-weight:300;color:var(--gold-l);line-height:1.1;letter-spacing:0.04em;margin-bottom:18px;}
.hero-title em{font-style:italic;color:var(--gold);}
.hero-sub{font-size:10px;letter-spacing:0.4em;color:var(--gray);margin-bottom:48px;}
.deco{display:none;}
.deco-bar{display:none;}
.deco-dia{display:none;}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.btn-primary{font-size:10px;letter-spacing:0.28em;color:var(--navy);background:var(--gold);padding:14px 30px;text-decoration:none;transition:background 0.3s;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;}
.btn-primary:hover{background:var(--gold-l);}
.btn-outline{font-size:10px;letter-spacing:0.28em;color:var(--gold);border:1px solid var(--gold);padding:14px 30px;text-decoration:none;background:transparent;transition:all 0.3s;}
.btn-outline:hover{background:rgba(201,168,76,0.08);}
/* PAGE HERO */
.page-hero{padding:140px 5vw 70px;text-align:center;background:radial-gradient(ellipse 70% 50% at 50% 30%,rgba(201,168,76,0.07) 0%,transparent 70%);}
.pre{font-size:10px;letter-spacing:0.45em;color:var(--gold);display:block;margin-bottom:14px;}
.page-hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,5vw,50px);font-weight:300;color:var(--gold-l);letter-spacing:0.05em;}
section{padding:90px 5vw;}
.section-header{text-align:center;margin-bottom:60px;}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,46px);font-weight:300;color:var(--gold-l);letter-spacing:0.05em;line-height:1.2;}
/* SERVICES */
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px;max-width:1200px;margin:0 auto;}
.service-card{background:var(--navy2);padding:46px 36px;position:relative;overflow:hidden;transition:all 0.4s;cursor:pointer;text-decoration:none;display:block;}
.service-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform 0.4s;transform-origin:left;}
.service-card:hover::before{transform:scaleX(1);}
.service-card:hover{background:#1e2f55;}
.service-num{font-family:'Cormorant Garamond',serif;font-size:54px;font-weight:300;color:rgba(201,168,76,0.08);position:absolute;top:16px;right:22px;line-height:1;}
.service-icon{width:44px;height:44px;border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;margin-bottom:20px;}
.service-icon svg{width:20px;height:20px;fill:none;stroke:var(--gold);stroke-width:1.5;}
.service-name{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;color:var(--gold-l);letter-spacing:0.08em;margin-bottom:6px;}
.service-sub{font-size:9px;letter-spacing:0.28em;color:var(--gold);margin-bottom:16px;}
.service-desc{font-size:13px;font-weight:300;color:var(--gray);line-height:1.8;margin-bottom:22px;}
.service-list{list-style:none;display:flex;flex-direction:column;gap:7px;}
.service-list li{font-size:12px;color:var(--text);letter-spacing:0.06em;display:flex;align-items:center;gap:10px;}
.service-list li::before{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0;}
.service-arrow{margin-top:28px;font-size:10px;letter-spacing:0.25em;color:var(--gold);display:flex;align-items:center;gap:10px;}
.service-arrow::after{content:'';flex:0 0 28px;height:1px;background:var(--gold);transition:flex 0.3s;}
.service-card:hover .service-arrow::after{flex:0 0 48px;}
/* ABOUT */
.about-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
.about-text p{font-size:13.5px;font-weight:300;color:var(--gray);line-height:1.95;margin-bottom:18px;}
.about-text .quote{font-family:'Cormorant Garamond',serif;font-size:20px;font-style:italic;color:var(--gold-l);line-height:1.6;margin-bottom:26px;padding-left:18px;border-left:2px solid var(--gold);}
.values-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.value-item{padding:22px;border:1px solid rgba(201,168,76,0.15);}
.value-title{font-size:9px;letter-spacing:0.3em;color:var(--gold);margin-bottom:7px;font-weight:600;}
.value-desc{font-size:12px;font-weight:300;color:var(--gray);line-height:1.7;}
/* CONTACT */
.contact-inner{max-width:620px;margin:0 auto;text-align:center;}
.contact-form{margin-top:46px;display:flex;flex-direction:column;gap:15px;text-align:left;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:15px;}
.form-group{display:flex;flex-direction:column;gap:7px;}
.form-group label{font-size:9px;letter-spacing:0.3em;color:var(--gold);}
.form-group input,.form-group textarea{background:rgba(255,255,255,0.04);border:1px solid rgba(201,168,76,0.22);color:var(--gold-l);font-family:'Montserrat',sans-serif;font-size:13px;font-weight:300;padding:13px 15px;outline:none;transition:border-color 0.3s;resize:none;}
.form-group input::placeholder,.form-group textarea::placeholder{color:var(--gray);opacity:0.7;}
.form-group input:focus,.form-group textarea:focus{border-color:var(--gold);}
.form-btn{font-size:10px;letter-spacing:0.28em;color:var(--navy);background:var(--gold);border:none;padding:15px;cursor:pointer;width:100%;font-family:'Montserrat',sans-serif;transition:background 0.3s;}
.form-btn:hover{background:var(--gold-l);}
.form-success{display:none;padding:15px;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.3);color:var(--gold-l);font-size:12px;letter-spacing:0.05em;text-align:center;margin-top:6px;}
/* MODALS */
.modal-overlay{position:fixed;inset:0;z-index:500;background:rgba(8,14,26,0.92);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity 0.35s;backdrop-filter:blur(4px);}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--navy2);border:1px solid rgba(201,168,76,0.35);max-width:660px;width:100%;max-height:90vh;overflow-y:auto;position:relative;transform:translateY(20px);transition:transform 0.35s;}
.modal-overlay.open .modal{transform:translateY(0);}
.modal-header{padding:34px 38px 22px;position:relative;}
.modal-close{position:absolute;top:18px;right:22px;background:none;border:none;color:var(--gray);font-size:20px;cursor:pointer;transition:color 0.3s;font-family:inherit;}
.modal-close:hover{color:var(--gold);}
.modal-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:300;color:rgba(201,168,76,0.1);line-height:1;margin-bottom:6px;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--gold-l);letter-spacing:0.06em;margin-bottom:5px;}
.modal-sub{font-size:9px;letter-spacing:0.28em;color:var(--gold);}
.modal-body{padding:28px 38px 38px;}
.modal-desc{font-size:13px;font-weight:300;color:var(--gray);line-height:1.9;margin-bottom:24px;font-style:italic;}
.modal-info-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:22px;}
.modal-info-item{padding:14px;background:rgba(14,22,41,0.6);border:1px solid rgba(201,168,76,0.14);text-align:center;}
.modal-info-label{font-size:8px;letter-spacing:0.28em;color:var(--gold);margin-bottom:5px;}
.modal-info-value{font-size:11px;font-weight:500;color:var(--gold-l);}
.modal-badge{display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border:1px solid rgba(201,168,76,0.3);font-size:9px;letter-spacing:0.18em;color:var(--gold);margin-bottom:24px;}
.modal-section-title{font-size:9px;letter-spacing:0.3em;color:var(--gold);margin-bottom:12px;font-weight:600;}
.modal-prestations{display:flex;flex-direction:column;gap:8px;margin-bottom:22px;}
.modal-prestation{display:flex;align-items:flex-start;gap:12px;padding:12px 16px;background:rgba(201,168,76,0.03);border:1px solid rgba(201,168,76,0.09);transition:border-color 0.3s;}
.modal-prestation:hover{border-color:rgba(201,168,76,0.25);}
.modal-prestation-dot{color:var(--gold);font-size:14px;flex-shrink:0;}
.modal-prestation-text{font-size:12.5px;font-weight:400;color:var(--text);line-height:1.5;}
.modal-prestation-text span{display:block;font-size:11px;color:var(--gray);margin-top:2px;font-weight:300;}
.modal-cta-btn{display:block;text-align:center;font-size:10px;letter-spacing:0.28em;color:var(--navy);background:var(--gold);padding:14px;cursor:pointer;border:none;width:100%;font-family:'Montserrat',sans-serif;transition:background 0.3s;}
.modal-cta-btn:hover{background:var(--gold-l);}
/* SERVICE PAGE */
.service-page-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;max-width:1100px;margin:0 auto;}
.svc-card{background:var(--navy2);padding:36px 32px;border:1px solid rgba(201,168,76,0.1);transition:border-color 0.3s;}
.svc-card:hover{border-color:rgba(201,168,76,0.3);}
.svc-card-num{font-size:9px;letter-spacing:0.3em;color:var(--gold);margin-bottom:10px;font-weight:600;}
.svc-card-name{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:var(--gold-l);margin-bottom:12px;}
.svc-card-desc{font-size:13px;font-weight:300;color:var(--gray);line-height:1.85;margin-bottom:16px;}
.svc-card-items{list-style:none;display:flex;flex-direction:column;gap:7px;margin-bottom:18px;}
.svc-card-items li{font-size:12px;color:var(--text);display:flex;align-items:center;gap:9px;}
.svc-card-items li::before{content:'';width:3px;height:3px;background:var(--gold);border-radius:50%;flex-shrink:0;}
.svc-card-price{font-size:10px;letter-spacing:0.15em;color:var(--gold);padding-top:14px;}
/* ABOUT PAGE */
.timeline{max-width:700px;margin:0 auto;display:flex;flex-direction:column;gap:0;}
.timeline-item{display:flex;gap:28px;padding-bottom:36px;position:relative;}
.timeline-item::before{content:'';position:absolute;left:19px;top:32px;bottom:0;width:1px;background:rgba(201,168,76,0.2);}
.timeline-item:last-child::before{display:none;}
.tl-dot{width:40px;height:40px;min-width:40px;border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;background:var(--navy2);z-index:1;}
.tl-dot span{font-size:14px;color:var(--gold);}
.tl-content h3{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--gold-l);margin-bottom:6px;}
.tl-content p{font-size:13px;font-weight:300;color:var(--gray);line-height:1.8;}
/* FOOTER */
footer{background:#080e1a;padding:36px 5vw;border-top:1px solid rgba(201,168,76,0.12);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.footer-brand{font-family:'Cormorant Garamond',serif;font-size:16px;letter-spacing:0.2em;color:var(--gold);}
.footer-copy{font-size:10px;letter-spacing:0.12em;color:var(--gray);}
.footer-links{display:flex;gap:22px;flex-wrap:wrap;}
.footer-links a{font-size:10px;letter-spacing:0.18em;color:var(--gray);text-decoration:none;transition:color 0.3s;}
.footer-links a:hover{color:var(--gold);}
/* COOKIE */
#cookie-banner{position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#0b1120;padding:20px 5vw;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;transform:translateY(100%);transition:transform 0.4s;}
.cookie-text{font-size:12px;font-weight:300;color:var(--gray);line-height:1.7;max-width:700px;}
.cookie-text a{color:var(--gold);}
.cookie-btns{display:flex;gap:10px;flex-shrink:0;}
.btn-refuse{font-size:10px;letter-spacing:0.2em;color:var(--gold);background:transparent;border:1px solid rgba(201,168,76,0.4);padding:10px 20px;cursor:pointer;font-family:inherit;transition:all 0.3s;}
.btn-accept{font-size:10px;letter-spacing:0.2em;color:var(--navy);background:var(--gold);border:none;padding:10px 22px;cursor:pointer;font-family:inherit;transition:background 0.3s;}
.btn-accept:hover{background:var(--gold-l);}
/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.hero-content>*{animation:fadeUp 0.8s ease forwards;opacity:0;}
.hero-pre{animation-delay:0.1s}.hero-logo{animation-delay:0.25s}
.hero-title{animation-delay:0.4s}.hero-sub{animation-delay:0.5s}
.deco{display:none;}.hero-btns{animation-delay:0.7s}
.fade-up{opacity:0;transform:translateY(24px);transition:opacity 0.7s ease,transform 0.7s ease;}
.fade-up.visible{opacity:1;transform:translateY(0);}
/* ZONE INFO BOX */
.zone-bar{background:var(--navy2);padding:20px 5vw;display:flex;justify-content:center;gap:60px;flex-wrap:wrap;}
.zone-item{display:flex;align-items:center;gap:10px;font-size:11px;color:var(--gray);letter-spacing:0.1em;}
.zone-item strong{color:var(--gold-l);}
.zone-dot{width:5px;height:5px;background:var(--gold);border-radius:50%;}
/* RESPONSIVE */
@media(max-width:900px){.nav-links,.nav-cta{display:none;}.hamburger{display:flex;}.about-inner{grid-template-columns:1fr;gap:40px;}.values-grid{grid-template-columns:1fr;}.form-row{grid-template-columns:1fr;}footer{flex-direction:column;text-align:center;}.modal-info-grid{grid-template-columns:1fr;}}
</style>

<style>
/* ── PAGE SERVICE — MODÈLE TIMELINE PRESTIGE ── */
.svc-hero {
  height: 60vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 120px 5vw 60px;
  position: relative; overflow: hidden;
  text-align: center;
}
.svc-hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 90% 70% at 50% 60%, rgba(201,168,76,0.08) 0%, transparent 65%);
}
.svc-hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(201,168,76,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(201,168,76,0.03) 1px, transparent 1px);
  background-size: 50px 50px;
}
.svc-hero-eyebrow {
  font-size: 9px; letter-spacing: 0.55em; color: var(--gold);
  margin-bottom: 18px; position: relative; z-index: 2;
}
.svc-hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(36px, 6vw, 68px); font-weight: 300;
  color: var(--gold-l); letter-spacing: 0.04em; line-height: 1.05;
  position: relative; z-index: 2; margin-bottom: 20px;
}
.svc-hero-title em { font-style: italic; color: var(--gold); }
.svc-hero-desc {
  font-size: 14px; font-weight: 300; color: var(--gray);
  max-width: 540px; line-height: 1.9; position: relative; z-index: 2;
  margin-bottom: 32px;
}
.svc-hero-cta {
  font-size: 10px; letter-spacing: 0.28em; color: var(--navy);
  background: var(--gold); padding: 14px 34px;
  text-decoration: none; transition: background 0.3s;
  position: relative; z-index: 2;
}
.svc-hero-cta:hover { background: var(--gold-l); }

/* ── TIMELINE PRESTATIONS ── */
.svc-timeline-section {
  padding: 100px 5vw;
  background: #0b1120;
}
.svc-timeline-inner {
  max-width: 900px; margin: 0 auto;
}
.svc-tl-header {
  text-align: center; margin-bottom: 80px;
}
.svc-tl-header .pre {
  font-size: 9px; letter-spacing: 0.5em; color: var(--gold);
  display: block; margin-bottom: 14px;
}
.svc-tl-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(26px, 4vw, 40px); font-weight: 300;
  color: var(--gold-l); letter-spacing: 0.06em;
}

.svc-tl-items { display: flex; flex-direction: column; gap: 0; }

.svc-tl-item {
  display: grid;
  grid-template-columns: 1fr 52px 1fr;
  gap: 0;
  min-height: 120px;
}

/* Alternance gauche/droite */
.svc-tl-item:nth-child(odd) .svc-tl-left  { order: 1; text-align: right; padding-right: 40px; }
.svc-tl-item:nth-child(odd) .svc-tl-center{ order: 2; }
.svc-tl-item:nth-child(odd) .svc-tl-right { order: 3; padding-left: 40px; opacity: 0; pointer-events: none; }

.svc-tl-item:nth-child(even) .svc-tl-left  { order: 1; opacity: 0; pointer-events: none; }
.svc-tl-item:nth-child(even) .svc-tl-center{ order: 2; }
.svc-tl-item:nth-child(even) .svc-tl-right { order: 3; padding-left: 40px; }

.svc-tl-left, .svc-tl-right {
  padding-top: 8px; padding-bottom: 40px;
  display: flex; flex-direction: column; justify-content: flex-start;
}
.svc-tl-center {
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 0;
}
.svc-tl-dot-wrap {
  display: flex; flex-direction: column; align-items: center; height: 100%;
}
.svc-tl-icon {
  width: 52px; height: 52px;
  border: 1px solid var(--gold);
  background: #0b1120;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; z-index: 1;
  transition: background 0.3s;
}
.svc-tl-item:hover .svc-tl-icon { background: rgba(201,168,76,0.08); }
.svc-tl-icon svg { width: 20px; height: 20px; fill: none; stroke: var(--gold); stroke-width: 1.3; }
.svc-tl-line {
  flex: 1; width: 1px; background: rgba(201,168,76,0.18); margin-top: 0;
}
.svc-tl-item:last-child .svc-tl-line { display: none; }

.svc-tl-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 400; color: var(--gold-l);
  letter-spacing: 0.06em; margin-bottom: 10px; line-height: 1.2;
}
.svc-tl-desc {
  font-size: 13px; font-weight: 300; color: var(--gray);
  line-height: 1.85;
}
.svc-tl-tags {
  display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px;
}
.svc-tl-item:nth-child(odd) .svc-tl-tags { justify-content: flex-end; }
.svc-tl-tag {
  font-size: 9px; letter-spacing: 0.12em; color: var(--gold);
  border: 0.5px solid rgba(201,168,76,0.3); padding: 4px 11px;
  transition: border-color 0.3s;
}
.svc-tl-item:hover .svc-tl-tag { border-color: rgba(201,168,76,0.6); }

/* ── BANDE DEVIS ── */
.svc-devis-band {
  padding: 70px 5vw; text-align: center;
  background: var(--navy2);
  
}
.svc-devis-quote {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(20px, 3vw, 28px); font-weight: 300; font-style: italic;
  color: var(--gold-l); max-width: 600px; margin: 0 auto 32px;
  line-height: 1.5;
}
.svc-devis-sub {
  font-size: 11px; letter-spacing: 0.25em; color: var(--gray);
  margin-bottom: 30px;
}
.svc-devis-cta {
  font-size: 10px; letter-spacing: 0.28em; color: var(--navy);
  background: var(--gold); padding: 15px 36px;
  text-decoration: none; transition: background 0.3s; display: inline-block;
}
.svc-devis-cta:hover { background: var(--gold-l); }

/* RESPONSIVE */
@media(max-width:760px){
  .svc-tl-item {
    grid-template-columns: 40px 1fr;
  }
  .svc-tl-item:nth-child(odd) .svc-tl-left,
  .svc-tl-item:nth-child(even) .svc-tl-left { display: none; }
  .svc-tl-item:nth-child(odd) .svc-tl-center,
  .svc-tl-item:nth-child(even) .svc-tl-center { order: 1; }
  .svc-tl-item:nth-child(odd) .svc-tl-right,
  .svc-tl-item:nth-child(even) .svc-tl-right { order: 2; padding-left: 20px; opacity: 1; pointer-events: all; }
  .svc-tl-item:nth-child(odd) .svc-tl-left  { opacity: 0; }
  .svc-tl-icon { width: 40px; height: 40px; }
  .svc-tl-icon svg { width: 16px; height: 16px; }
}
</style>

</head>
