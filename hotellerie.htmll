<script>

const T={fr:{nav_home:"Accueil",nav_services:"Services",nav_concierge:"Conciergerie",nav_hotel:"H\u00f4tellerie",nav_event:"\u00c9v\u00e9nementiel",nav_about:"\u00c0 propos",nav_contact:"Contact",nav_legal:"Mentions l\u00e9gales",nav_rgpd:"Donn\u00e9es personnelles",nav_cta:"Nous contacter",hero_pre:"PRESTIGE \u00b7 EXCELLENCE \u00b7 DISCR\u00c9TION",hero_title:"L\u2019art de vivre<br><em>autrement</em>",hero_sub:"CONCIERGERIE \u00b7 H\u00d4TELLERIE \u00b7 \u00c9V\u00c9NEMENTIEL",hero_btn1:"D\u00e9couvrir nos services",hero_btn2:"Prendre contact",svc_pre:"NOS EXPERTISES",svc_title:"Trois univers,<br>une seule exigence",svc1_name:"Conciergerie",svc1_sub:"CONCIERGERIE \u00b7 PRESTIGE",svc1_desc:"Un service sur-mesure pour simplifier votre quotidien.",svc1_items:["Courses & approvisionnement","Transport & d\u00e9placements","M\u00e9nage & linge","Assistance administrative","Gestion locative","Petits travaux"],svc2_name:"H\u00f4tellerie",svc2_sub:"SERVICES H\u00d4TELIERS \u00b7 PRESTIGE",svc2_desc:"Des prestations haut de gamme pour les \u00e9tablissements h\u00f4teliers.",svc2_items:["Accueil & r\u00e9ception","M\u00e9nage chambres","Restauration","Bien-\u00eatre & spa"],svc3_name:"\u00c9v\u00e9nementiel",svc3_sub:"\u00c9V\u00c9NEMENTIEL \u00b7 PRESTIGE",svc3_desc:"De la conception \u00e0 la r\u00e9alisation, vos \u00e9v\u00e9nements orchestr\u00e9s \u00e0 la perfection.",svc3_items:["Mariages & c\u00e9r\u00e9monies","\u00c9v\u00e9nements corporate","Soir\u00e9es priv\u00e9es","Coordination"],svc_more:"EN SAVOIR PLUS",about_pre:"NOTRE HISTOIRE",about_title:"L\u2019excellence<br>au service<br>de votre vie",about_quote:'"Nous ne proposons pas simplement des services."',about_p1:"Apog\u00e9e & Co est n\u00e9e d\u2019une conviction profonde.",about_p2:"De la gestion quotidienne \u00e0 l\u2019organisation d\u2019\u00e9v\u00e9nements d\u2019exception.",val1_t:"EXCELLENCE",val1_d:"Chaque prestation r\u00e9alis\u00e9e avec le plus haut niveau d\u2019exigence.",val2_t:"DISCR\u00c9TION",val2_d:"Votre vie priv\u00e9e est notre priorit\u00e9 absolue.",val3_t:"DISPONIBILIT\u00c9",val3_d:"Un accompagnement 7j/7 pour toutes vos demandes.",val4_t:"SUR-MESURE",val4_d:"Chaque service personnalis\u00e9 selon vos pr\u00e9f\u00e9rences.",contact_pre:"NOUS CONTACTER",contact_title:"Parlons de<br>votre projet",f_name:"NOM",f_email:"EMAIL",f_phone:"T\u00c9L\u00c9PHONE",f_service:"SERVICE SOUHAIT\u00c9",f_service_ph:"Conciergerie / H\u00f4tellerie / \u00c9v\u00e9nementiel",f_msg:"VOTRE MESSAGE",f_msg_ph:"D\u00e9crivez votre projet ou votre demande...",f_submit:"ENVOYER LE MESSAGE",f_sending:"ENVOI EN COURS...",f_success:"\u2713 Message envoy\u00e9.",f_error:"ERREUR",footer_copy:"\u00a9 2025 Apog\u00e9e & Co \u2014 SIRET 980 327 670 00017",cookie_text:"Nous utilisons des cookies essentiels.",cookie_more:"En savoir plus",cookie_refuse:"REFUSER",cookie_accept:"ACCEPTER",cookie_customize:"Personnaliser",modal_tarif:"TARIF",modal_zone:"ZONE",modal_delai:"D\u00c9LAI",modal_zone_val:"International",modal_tarif_val:"Sur devis personnalis\u00e9",modal_badge:"\u2605 EXP\u00c9RIENCE PREMIUM GARANTIE",modal_prestations:"NOS PRESTATIONS",modal_cta:"DEMANDER UN DEVIS PERSONNALIS\u00c9",modal_delai_c:"Intervention sous 48h",modal_delai_h:"Sur planification",modal_delai_e:"Sur planification",page_concierge_pre:"CONCIERGERIE PRESTIGE",page_concierge_title:"Nos services de conciergerie",page_hotel_pre:"H\u00d4TELLERIE PRESTIGE",page_hotel_title:"Nos services h\u00f4teliers",page_event_pre:"\u00c9V\u00c9NEMENTIEL PRESTIGE",page_event_title:"Nos services \u00e9v\u00e9nementiels",page_about_pre:"APOG\u00c9E & CO",page_about_title:"\u00c0 propos de nous",zone_label:"",zone_val:"",lang_btn:"EN"},en:{nav_home:"Home",nav_concierge:"Concierge",nav_hotel:"Hospitality",nav_event:"Events",nav_about:"About",nav_contact:"Contact",nav_legal:"Legal notice",nav_rgpd:"Privacy policy",nav_cta:"Contact us",hero_pre:"PRESTIGE \u00b7 EXCELLENCE \u00b7 DISCRETION",hero_title:"The art of living<br><em>differently</em>",hero_sub:"CONCIERGE \u00b7 HOSPITALITY \u00b7 EVENTS",hero_btn1:"Discover our services",hero_btn2:"Get in touch",svc_pre:"OUR EXPERTISE",svc_title:"Three worlds,<br>one standard",svc1_name:"Concierge",svc1_sub:"CONCIERGE \u00b7 PRESTIGE",svc1_desc:"A bespoke service to simplify your daily life.",svc1_items:["Grocery & provisioning","Transportation","Cleaning & laundry","Administrative assistance","Property management","Minor repairs"],svc2_name:"Hospitality",svc2_sub:"HOTEL SERVICES \u00b7 PRESTIGE",svc2_desc:"Premium hospitality services for demanding establishments.",svc2_items:["Guest welcome","Room cleaning","Catering","Wellness & spa"],svc3_name:"Events",svc3_sub:"EVENTS \u00b7 PRESTIGE",svc3_desc:"From concept to execution, your events orchestrated to perfection.",svc3_items:["Weddings & ceremonies","Corporate events","Private parties","Full coordination"],svc_more:"LEARN MORE",about_pre:"OUR STORY",about_title:"Excellence<br>at the service<br>of your life",about_quote:'"We craft experiences that last."',about_p1:"Born from a deep conviction: every client deserves unique attention.",about_p2:"From daily management to exceptional events, your trusted partner.",val1_t:"EXCELLENCE",val1_d:"Every service delivered with the highest standards.",val2_t:"DISCRETION",val2_d:"Your privacy is our absolute priority.",val3_t:"AVAILABILITY",val3_d:"Support 7 days a week for all your requests.",val4_t:"BESPOKE",val4_d:"Every service personalised to your preferences.",contact_pre:"CONTACT US",contact_title:"Let us talk about<br>your project",f_name:"NAME",f_email:"EMAIL",f_phone:"PHONE",f_service:"SERVICE REQUESTED",f_service_ph:"Concierge / Hospitality / Events",f_msg:"YOUR MESSAGE",f_msg_ph:"Describe your project...",f_submit:"SEND MESSAGE",f_sending:"SENDING...",f_success:"\u2713 Message sent.",f_error:"ERROR",footer_copy:"\u00a9 2025 Apog\u00e9e & Co \u2014 SIRET 980 327 670 00017",cookie_text:"We use essential cookies.",cookie_more:"Learn more",cookie_refuse:"DECLINE",cookie_accept:"ACCEPT",cookie_customize:"Customise",modal_tarif:"PRICE",modal_zone:"AREA",modal_delai:"LEAD TIME",modal_zone_val:"International",modal_tarif_val:"Custom quote",modal_badge:"\u2605 PREMIUM EXPERIENCE GUARANTEED",modal_prestations:"OUR SERVICES",modal_cta:"REQUEST A CUSTOM QUOTE",modal_delai_c:"Within 48 hours",modal_delai_h:"Upon scheduling",modal_delai_e:"Upon scheduling",page_concierge_pre:"PRESTIGE CONCIERGE",page_concierge_title:"Our concierge services",page_hotel_pre:"PRESTIGE HOSPITALITY",page_hotel_title:"Our hotel services",page_event_pre:"PRESTIGE EVENTS",page_event_title:"Our event services",page_about_pre:"APOG\u00c9E & CO",page_about_title:"About us",zone_label:"",zone_val:"",lang_btn:"FR"}};
let lang=localStorage.getItem("apogee_lang")||"fr";
function t(k){return T[lang][k]||T.fr[k]||k;}
function setLang(l){lang=l;localStorage.setItem("apogee_lang",l);document.querySelectorAll("[data-t]").forEach(el=>{const k=el.getAttribute("data-t");if(el.tagName==="INPUT"||el.tagName==="TEXTAREA")el.placeholder=t(k);else if(el.hasAttribute("data-html"))el.innerHTML=t(k);else el.textContent=t(k);});document.querySelectorAll("[data-t-list]").forEach(el=>{const k=el.getAttribute("data-t-list");const items=t(k);if(Array.isArray(items))el.innerHTML=items.map(i=>"<li>"+i+"</li>").join("");});document.querySelectorAll(".lang-btn").forEach(b=>b.textContent=t("lang_btn"));}
function toggleLang(){setLang(lang==="fr"?"en":"fr");}

document.addEventListener('DOMContentLoaded',()=>{
  setLang(lang);
  window.addEventListener('scroll',()=>document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>50));
  const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible');});},{threshold:0.1});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
  if(!localStorage.getItem('cookie_consent_v2'))setTimeout(()=>{const b=document.getElementById('cookie-banner');if(b)b.style.transform='translateY(0)';},1000);
  const path=window.location.pathname.split('/').pop()||'index.html';
  document.querySelectorAll('.nav-links a,.mobile-menu a').forEach(a=>{if(a.getAttribute('href')===path||a.getAttribute('href').split('#')[0]===path)a.classList.add('active');});
});
function toggleMenu(){document.getElementById('mobileMenu').classList.toggle('open');}
function acceptCookies(){localStorage.setItem('cookie_consent_v2',JSON.stringify({v:'1.0',ts:new Date().toISOString(),a:true}));document.getElementById('cookie-banner').style.transform='translateY(100%)';}
function refuseCookies(){localStorage.setItem('cookie_consent_v2',JSON.stringify({v:'1.0',ts:new Date().toISOString(),a:false}));document.getElementById('cookie-banner').style.transform='translateY(100%)';}
function openModal(id){document.getElementById('modal-'+id).classList.add('open');document.body.style.overflow='hidden';}
function closeModal(id){document.getElementById('modal-'+id).classList.remove('open');document.body.style.overflow='';}
function closeOnOverlay(e,id){if(e.target===e.currentTarget)closeModal(id);}
document.addEventListener('keydown',e=>{if(e.key==='Escape')['conciergerie','hotellerie','evenementiel'].forEach(closeModal);});
</script>
</body>
</html>
